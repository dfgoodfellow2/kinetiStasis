# Server
PORT=8080
ENV=development
DB_PATH=./data/diet.db

# Custom domain (used for CORS in production)
APP_DOMAIN=https://your-domain.com

# Auth — generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# Gemini AI (get from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your-gemini-api-key-here

# Litestream backup — Tigris (or any S3-compatible)
# Create bucket at https://console.tigris.dev
LITESTREAM_BUCKET=your-bucket-name
LITESTREAM_REGION=auto
LITESTREAM_ACCESS_KEY_ID=your-access-key
LITESTREAM_SECRET_ACCESS_KEY=your-secret-key
LITESTREAM_ENDPOINT=https://fly.storage.tigris.dev
